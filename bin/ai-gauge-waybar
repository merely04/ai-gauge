#!/usr/bin/env bun

const WS_URL = Bun.env.AIGAUGE_WS_URL || 'ws://localhost:19876';
import { render } from '../lib/render-waybar.js';
const RECONNECT_DELAY = 5_000;

let lastUsageCache = null;
let lastUpdateState = {
  available: false,
  version: null,
  installing: false,
  error: null,
  changelogUrl: null,
};

function printWaiting() {
  process.stdout.write(JSON.stringify({
    text: '✦ ···',
    class: 'waiting',
    tooltip: 'Connecting to ai-gauge-server...',
  }) + '\n');
}

function handleTypedMessage(data) {
  switch (data.type) {
    case 'updateAvailable':
      lastUpdateState = {
        available: true,
        version: data.latestVersion,
        installing: false,
        error: null,
        changelogUrl: data.changelogUrl || null,
      };
      renderWithCurrentState();
      break;
    case 'updateInstalling':
      lastUpdateState = { ...lastUpdateState, installing: true, error: null };
      renderWithCurrentState();
      break;
    case 'updateFailed':
      lastUpdateState = { ...lastUpdateState, installing: false, error: data.reason };
      renderWithCurrentState();
      break;
    case 'updateComplete':
      lastUpdateState = {
        available: false,
        version: null,
        installing: false,
        error: null,
        changelogUrl: null,
      };
      renderWithCurrentState();
      break;
    case 'updateCheckFailed':
    case 'updateAlreadyInProgress':
      process.stderr.write('[ai-gauge-waybar] ignoring typed: ' + data.type + '\n');
      break;
    default:
      process.stderr.write('[ai-gauge-waybar] ignoring typed: ' + data.type + '\n');
  }
}

function renderWithCurrentState() {
  if (lastUsageCache) {
    const out = render(lastUsageCache, lastUpdateState);
    process.stdout.write(JSON.stringify(out) + '\n');
  }
}

function resetUpdateState() {
  lastUpdateState = {
    available: false,
    version: null,
    installing: false,
    error: null,
    changelogUrl: null,
  };
}

function connect() {
  let closed = false;
  const ws = new WebSocket(WS_URL);

  ws.onmessage = (event) => {
    try {
      const payload = typeof event.data === 'string' ? event.data : String(event.data);
      const data = JSON.parse(payload);
      if (data && typeof data.type === 'string') {
        handleTypedMessage(data);
      } else {
        lastUsageCache = data;
        const out = render(data, lastUpdateState);
        process.stdout.write(JSON.stringify(out) + '\n');
      }
    } catch (err) {
      process.stderr.write('[ai-gauge-waybar] parse error: ' + (err?.message || err) + '\n');
    }
  };

  ws.onerror = () => {};

  ws.onclose = () => {
    if (closed) return;
    closed = true;
    resetUpdateState();
    printWaiting();
    setTimeout(connect, RECONNECT_DELAY);
  };
}

printWaiting();
connect();
setInterval(() => {}, 60_000);
