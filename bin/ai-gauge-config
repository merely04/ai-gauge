#!/usr/bin/env bash
set -euo pipefail

# Resolve package directory (follows symlinks from global bin).
if readlink -f "${BASH_SOURCE[0]}" >/dev/null 2>&1; then
    SELF="$(readlink -f "${BASH_SOURCE[0]}")"
else
    SELF="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "${BASH_SOURCE[0]}")"
fi
SCRIPT_DIR="$(dirname "$SELF")"
source "$SCRIPT_DIR/../lib/bash-helpers.sh"

CONFIG_DIR="$HOME/.config/ai-gauge"
CONFIG_FILE="$CONFIG_DIR/config.json"

mkdir -p "$CONFIG_DIR"

read_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        cat "$CONFIG_FILE"
    else
        echo '{"tokenSource":"claude-code","plan":"unknown"}'
    fi
}

get_field() {
    read_config | jq -r ".$1 // empty"
}

set_field() {
    local key="$1" value="$2"
    local config
    config=$(read_config)
    echo "$config" | jq --arg k "$key" --arg v "$value" '.[$k] = $v' > "$CONFIG_FILE"
}

restart_server() {
    systemctl --user restart ai-gauge-server 2>/dev/null || true
}

send_ws() {
    if [[ "${DRY_RUN:-0}" == "1" ]]; then
        echo "WOULD_SEND: $1"
    else
        echo "$1" | bun "$SCRIPT_DIR/../lib/send-ws.js"
    fi
}

# CLI mode
if [[ "${1:-}" == "get" ]]; then
    if [[ -n "${2:-}" ]]; then
        get_field "$2"
    else
        read_config | jq .
    fi
    exit 0
fi

if [[ "${1:-}" == "set" ]]; then
    if [[ -z "${2:-}" || -z "${3:-}" ]]; then
        echo "Usage: ai-gauge-config set <key> <value>" >&2
        exit 1
    fi
    if [[ "$2" == "autoCheckUpdates" ]]; then
        if [[ "$3" == "true" ]]; then
            json_value="true"
        elif [[ "$3" == "false" ]]; then
            json_value="false"
        else
            echo "Error: autoCheckUpdates must be true or false" >&2
            exit 1
        fi
        if [[ "${DRY_RUN:-0}" == "1" ]]; then
            echo "WOULD_SET: autoCheckUpdates=$3"
        else
            send_ws "{\"type\":\"setConfig\",\"key\":\"autoCheckUpdates\",\"value\":${json_value}}"
        fi
        echo "Set autoCheckUpdates = $3"
        exit 0
    fi
    set_field "$2" "$3"
    echo "Set $2 = $3"
    restart_server
    exit 0
fi

# Interactive mode (walker UI)
# Skip walker UI on macOS
if is_macos && [[ "${DRY_RUN:-0}" != "1" && -z "${SELECTED_ITEM:-}" ]]; then
    echo "Config UI available via menubar right-click submenu."
    echo "For CLI use: ai-gauge-config set <key> <value>"
    echo "  Keys: plan (max|pro|team|enterprise|unknown), tokenSource (claude-code|opencode), autoCheckUpdates (true|false)"
    exit 0
fi

current_source=$(get_field tokenSource)
current_plan=$(get_field plan)
current_auto_check_updates=$(get_field autoCheckUpdates)

items=(
    "🔑  Token Source: ${current_source:-claude-code}"
    "📋  Plan: ${current_plan:-unknown}"
    "🔄  Auto-check updates: $(if [[ "${current_auto_check_updates:-true}" == "true" ]]; then echo ON; else echo OFF; fi)"
)

if [[ "${DRY_RUN:-0}" == "1" ]]; then
    printf '%s\n' "${items[@]}"
    choice="${SELECTED_ITEM:-}"
elif [[ -n "${SELECTED_ITEM:-}" ]]; then
    choice="$SELECTED_ITEM"
else
    choice=$(printf '%s\n' "${items[@]}" | omarchy-launch-walker --dmenu --width 260 --minheight 1 --maxheight 200 -p "Settings" 2>/dev/null) || exit 0
fi

case "$choice" in
    *"Token Source"*)
        if [[ "${DRY_RUN:-0}" == "1" ]]; then
            echo "WOULD_SET: tokenSource"
            exit 0
        fi
        new_source=$(printf '%s\n' "claude-code" "opencode" \
            | omarchy-launch-walker --dmenu --width 200 --minheight 1 --maxheight 150 -p "Token Source" 2>/dev/null
        ) || exit 0
        set_field "tokenSource" "$new_source"
        notify-send -t 2000 -a "AI Gauge" "Token source: $new_source"
        restart_server
        ;;
    *"Plan"*)
        if [[ "${DRY_RUN:-0}" == "1" ]]; then
            echo "WOULD_SET: plan"
            exit 0
        fi
        new_plan=$(printf '%s\n' "max" "pro" "team" "enterprise" "unknown" \
            | omarchy-launch-walker --dmenu --width 200 --minheight 1 --maxheight 200 -p "Plan" 2>/dev/null
        ) || exit 0
        set_field "plan" "$new_plan"
        notify-send -t 2000 -a "AI Gauge" "Plan: $new_plan"
        restart_server
        ;;
    *"Auto-check updates"*)
        if [[ "${current_auto_check_updates:-true}" == "true" ]]; then
            new_auto_check_updates=false
        else
            new_auto_check_updates=true
        fi
        if [[ "${DRY_RUN:-0}" == "1" ]]; then
            echo "WOULD_SET: autoCheckUpdates=$new_auto_check_updates"
        else
            send_ws "{\"type\":\"setConfig\",\"key\":\"autoCheckUpdates\",\"value\":${new_auto_check_updates}}"
        fi
        echo "Set autoCheckUpdates = $new_auto_check_updates"
        ;;
esac
