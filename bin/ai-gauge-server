#!/usr/bin/env bun

import { systemNotify } from '../lib/notify.js';
import { readConfig, validateConfigChange, applyConfigChange, CONFIG_PATH } from '../lib/config.js';
import { addClient, removeClient, broadcast, sendToClient } from '../lib/broadcast.js';
import { createThresholdNotifier } from '../lib/threshold-notify.js';
import { createUpdateLifecycle } from '../lib/update-lifecycle.js';
import { atomicWriteJSON } from '../lib/atomic-write.js';
import { readClaudeCodeCredentials, readOpenCodeCredentials, isTokenValid, CREDS_FILE, OPENCODE_AUTH_FILE_PRIMARY, OPENCODE_AUTH_FILE_MAC } from '../lib/credentials.js';
import { readCopilotCredentials } from '../lib/credentials-copilot.js';
import { readCodexCredentials } from '../lib/credentials-codex.js';
import { discoverSettingsFiles, readSettingsFileForCreds } from '../lib/settings-discovery.js';
import { logJson, sanitizeError } from '../lib/log-safe.js';
import { buildMeta, PACKAGE_VERSION } from '../lib/meta.js';
import { loadCachedUsage } from '../lib/cache-loader.js';
import { getProvider } from '../lib/providers/index.js';
import { validateProviderUrl } from '../lib/ssrf-guard.js';
import '../lib/providers/anthropic.js';
import '../lib/providers/zai.js';
import '../lib/providers/minimax.js';
import '../lib/providers/openrouter.js';
import '../lib/providers/komilion.js';
import '../lib/providers/packy.js';
import '../lib/providers/copilot.js';
import '../lib/providers/codex.js';
import '../lib/providers/unknown.js';

const STATE_DIR = `${process.platform === 'darwin' ? (process.env.TMPDIR || '/tmp') : (process.env.XDG_RUNTIME_DIR || '/tmp')}/ai-gauge`;
const CLAUDE_DIR = `${process.env.HOME}/.claude`;
const WS_PORT = Number(Bun.env.AIGAUGE_WS_PORT) || 19876;
const POLL_INTERVAL = 60_000;
const BACKOFF_INTERVAL = 300_000;

const UPDATE_CHECK_INTERVAL_MS = Number(Bun.env.AIGAUGE_UPDATE_CHECK_INTERVAL_MS) || (24 * 60 * 60 * 1000);
const UPDATE_CHECK_INITIAL_DELAY_MS = Number(Bun.env.AIGAUGE_UPDATE_CHECK_INITIAL_DELAY_MS) || (30 * 1000);
const UPDATE_SPAWN_TIMEOUT_MS = Number(Bun.env.AIGAUGE_UPDATE_SPAWN_TIMEOUT_MS) || (120 * 1000);
const UPDATE_FETCH_TIMEOUT_MS = Number(Bun.env.AIGAUGE_UPDATE_FETCH_TIMEOUT_MS) || (10 * 1000);
const REGISTRY_URL = Bun.env.AIGAUGE_REGISTRY_URL || 'https://registry.npmjs.org';

let claudeVersion = '2.1.100';
let cachedData = null;
let currentInterval = POLL_INTERVAL;
let server;
let fetchInFlight = null;
let _fetchImpl = null;
let _readCredentialsImpl = null;
let fetchGeneration = 0;
let currentAbortController = null;

function shouldCodexFallbackOnStatus(status) {
  return status === 401 || status === 403 || (typeof status === 'number' && status >= 500);
}

function logError(message) {
  console.error(message);
}

async function readCredentials(config) {
  const src = config.tokenSource;

  if (src === 'claude-code') {
    const c = await readClaudeCodeCredentials();
    if (c) {
      logJson(console.error, 'credentials_loaded', { source: 'claude-code', provider: 'anthropic' });
      return { ...c, tokenSource: src, provider: 'anthropic', baseUrl: null };
    }
    logJson(console.error, 'credentials_missing', { source: 'claude-code' });
    return null;
  }

  if (src === 'opencode') {
    const c = await readOpenCodeCredentials();
    if (c) {
      logJson(console.error, 'credentials_loaded', {
        source: 'opencode',
        provider: 'anthropic',
        secondary: c.secondary ? c.secondary.provider : null,
      });
      return { ...c, tokenSource: src, provider: 'anthropic', baseUrl: null };
    }
    logJson(console.error, 'credentials_missing', { source: 'opencode' });
    return null;
  }

  if (src === 'codex') {
    const c = await readCodexCredentials();
    if (c) {
      logJson(console.error, 'credentials_loaded', { source: 'codex', provider: 'codex' });
      return { ...c, tokenSource: src, provider: 'codex', baseUrl: null };
    }
    logJson(console.error, 'credentials_missing', { source: 'codex' });
    return null;
  }

  if (src === 'github') {
    const c = await readCopilotCredentials();
    if (!c) {
      logJson(console.error, 'credentials_missing', { source: 'github', reason: 'no-gh-cli-no-pat' });
      return null;
    }
    logJson(console.error, 'credentials_loaded', { source: 'github', provider: 'copilot', credSource: c.source });
    return {
      token: c.token,
      expiresAt: null,
      subscriptionType: 'unknown',
      tokenSource: src,
      baseUrl: null,
      provider: 'copilot',
    };
  }

  if (src.startsWith('claude-settings:')) {
    const name = src.slice('claude-settings:'.length);
    const bundle = readSettingsFileForCreds(CLAUDE_DIR, name);
    if (!bundle) {
      logJson(console.warn, 'settings_unreadable', { name, tokenSource: src });
      return null;
    }
    logJson(console.error, 'credentials_loaded', { source: src, provider: bundle.provider });
    return {
      token: bundle.token,
      expiresAt: null,
      subscriptionType: 'unknown',
      tokenSource: src,
      baseUrl: bundle.baseUrl,
      provider: bundle.provider,
    };
  }

  logJson(console.warn, 'credentials_unknown_source', { source: src });
  return null;
}

async function detectClaudeVersion() {
  try {
    const proc = Bun.spawn(['claude', '--version'], {
      stdout: 'pipe',
      stderr: 'ignore',
    });
    const text = await new Response(proc.stdout).text();
    await proc.exited;
    const match = text.match(/[\d.]+/);
    if (match?.[0]) claudeVersion = match[0];
  } catch {
    claudeVersion = '2.1.100';
  }
}

async function writeUsageAtomic(data) {
  await atomicWriteJSON(`${STATE_DIR}/usage.json`, data, {
    validate: (parsed) => !!(parsed?.five_hour || parsed?.balance || parsed?.copilot),
  });
  await Bun.write(`${STATE_DIR}/last_fetch`, String(Math.floor(Date.now() / 1000)));
}

function formatDuration(resetsAt) {
  if (!resetsAt) return '?';
  const remaining = Math.max(0, (new Date(resetsAt).getTime() - Date.now()) / 1000);
  if (remaining <= 0) return 'now';
  const hours = Math.floor(remaining / 3600);
  const mins = Math.floor((remaining % 3600) / 60);
  return hours > 0 ? `${hours}h${String(mins).padStart(2, '0')}m` : `${mins}m`;
}

function formatDaysRemaining(resetsAt) {
  if (!resetsAt) return '?';
  const remaining = Math.max(0, (new Date(resetsAt).getTime() - Date.now()) / 1000);
  if (remaining <= 0) return '0';
  const days = Math.floor(remaining / 86400);
  return days > 0 ? String(days) : '<1';
}

const thresholdNotifier = createThresholdNotifier({
  broadcast,
  systemNotify,
  formatDuration,
  formatDaysRemaining,
});

const copilotThresholdNotifier = createThresholdNotifier({
  broadcast,
  systemNotify,
  formatDuration,
  formatDaysRemaining,
  extractor: (d) => {
    const pi = d?.copilot?.premium_interactions;
    if (!pi) return null;
    return {
      utilization: pi.utilization,
      resets_at: pi.resets_at,
      daysResetAt: pi.resets_at,
    };
  },
  messagePrefix: 'Copilot premium',
});

const updateLifecycle = createUpdateLifecycle({
  packageVersion: PACKAGE_VERSION,
  registryUrl: REGISTRY_URL,
  stateDir: STATE_DIR,
  installBinaryDir: import.meta.dir,
  fetchTimeoutMs: UPDATE_FETCH_TIMEOUT_MS,
  spawnTimeoutMs: UPDATE_SPAWN_TIMEOUT_MS,
  intervalMs: UPDATE_CHECK_INTERVAL_MS,
  initialDelayMs: UPDATE_CHECK_INITIAL_DELAY_MS,
  readConfig,
  broadcast,
  systemNotify,
  logger: logError,
});

export function setFetchImpl(fn) {
  _fetchImpl = fn;
}

export function setReadCredentialsImpl(fn) {
  _readCredentialsImpl = fn;
}

function doFetch(url, opts) {
  return (_fetchImpl ?? globalThis.fetch)(url, opts);
}

function rereadCredentials(config) {
  return (_readCredentialsImpl ?? readCredentials)(config);
}

async function fetchUsage(creds, config, { generation, signal, _retriedAfterAuth = false } = {}) {
  if (!creds || !creds.token) {
    if (config?.tokenSource === 'codex') {
      return await tryCodexJsonlFallback(
        { provider: 'codex', subscriptionType: 'unknown' },
        config ?? await readConfig(),
        { generation }
      );
    }
    return false;
  }
  if (creds.expiresAt !== null && !isTokenValid(creds.expiresAt)) {
    logJson(console.error, 'token_expired', { source: creds.tokenSource });
    if (creds.provider === 'codex') {
      return await tryCodexJsonlFallback(creds, config ?? await readConfig(), { generation });
    }
    return false;
  }

  const effectiveConfig = config ?? await readConfig();

  const providerName = creds.provider ?? 'anthropic';
  const adapter = getProvider(providerName);

  if (creds.baseUrl) {
    const ssrf = validateProviderUrl(creds.baseUrl);
    if (!ssrf.allowed) {
      logJson(console.warn, 'ssrf_blocked', { reason: ssrf.reason, provider: providerName });
      return false;
    }
  }

  if (adapter.kind === 'stub') {
    logJson(console.warn, 'provider_stub_no_api', { provider: providerName });
    return false;
  }

  try {
    const req = adapter.buildRequest(
      { token: creds.token, claudeVersion, account_id: creds.account_id },
      { baseUrl: creds.baseUrl }
    );

    const timeoutSignal = AbortSignal.timeout(10_000);
    const fetchSignal = signal
      ? (typeof AbortSignal.any === 'function'
          ? AbortSignal.any([signal, timeoutSignal])
          : timeoutSignal)
      : timeoutSignal;

    const res = await doFetch(req.url, {
      method: req.method ?? 'GET',
      headers: req.headers,
      redirect: 'manual',
      signal: fetchSignal,
    });

    if (res.status >= 300 && res.status < 400) {
      logJson(console.warn, 'fetch_redirect_rejected', { status: res.status, provider: providerName });
      return false;
    }

    let json = null;
    try {
      json = await res.json();
    } catch {}

    const parsed = adapter.parseResponse(json, res.status);
    if (parsed.error) {
      const status = parsed.error.status;
      const isAuthError = status === 401 || status === 403;
      if (isAuthError && !_retriedAfterAuth && (providerName === 'anthropic' || providerName === 'copilot') && creds.tokenSource && !creds.baseUrl) {
        const fresh = await rereadCredentials(effectiveConfig);
        if (fresh?.token && fresh.token !== creds.token) {
          logJson(console.warn, 'token_rotation_retry', { provider: providerName, status });
          return await fetchUsage(fresh, effectiveConfig, { generation, signal, _retriedAfterAuth: true });
        }
      }
      logJson(console.warn, 'provider_error', {
        provider: providerName,
        ...sanitizeError(new Error(parsed.error.reason ?? 'unknown')),
      });
      if (creds.provider === 'codex' && shouldCodexFallbackOnStatus(status)) {
        return await tryCodexJsonlFallback(creds, effectiveConfig, { generation });
      }
      return false;
    }

    if (generation != null && generation !== fetchGeneration) return false;

    const secondary = creds.secondary ? await fetchSecondary(creds.secondary, signal) : null;
    if (generation != null && generation !== fetchGeneration) return false;

    cachedData = {
      ...(parsed.rateLimits ?? {}),
      balance: parsed.balance ?? null,
      copilot: parsed.copilot ?? null,
      secondary,
      meta: buildMeta(effectiveConfig, {
        subscriptionType: creds.subscriptionType,
        provider: creds.provider,
      }),
    };

    await writeUsageAtomic(cachedData);
    return true;
  } catch (err) {
    if (signal?.aborted) return false;
    logJson(console.warn, 'fetch_error', { provider: providerName, ...sanitizeError(err) });
    if (creds.provider === 'codex') {
      return await tryCodexJsonlFallback(creds, effectiveConfig, { generation });
    }
    return false;
  }
}

async function fetchSecondary(secondaryCreds, signal) {
  if (!secondaryCreds?.token || !secondaryCreds?.account_id) return null;
  if (secondaryCreds.expiresAt !== null && !isTokenValid(secondaryCreds.expiresAt)) {
    logJson(console.error, 'secondary_token_expired', { provider: secondaryCreds.provider });
    return null;
  }

  const adapter = getProvider(secondaryCreds.provider ?? 'codex');
  if (adapter.kind === 'stub') return null;

  try {
    const req = adapter.buildRequest(
      { token: secondaryCreds.token, account_id: secondaryCreds.account_id, claudeVersion },
      { baseUrl: null }
    );
    const timeoutSignal = AbortSignal.timeout(10_000);
    const fetchSignal = signal && typeof AbortSignal.any === 'function'
      ? AbortSignal.any([signal, timeoutSignal])
      : timeoutSignal;

    const res = await doFetch(req.url, {
      method: req.method ?? 'GET',
      headers: req.headers,
      redirect: 'manual',
      signal: fetchSignal,
    });

    if (res.status >= 300 && res.status < 400) return null;

    let json = null;
    try { json = await res.json(); } catch {}

    const parsed = adapter.parseResponse(json, res.status);
    if (parsed.error) {
      logJson(console.warn, 'secondary_provider_error', {
        provider: secondaryCreds.provider,
        ...sanitizeError(new Error(parsed.error.reason ?? 'unknown')),
      });
      return null;
    }

    return {
      provider: secondaryCreds.provider,
      ...(parsed.rateLimits ?? {}),
      balance: parsed.balance ?? null,
    };
  } catch (err) {
    if (signal?.aborted) return null;
    logJson(console.warn, 'secondary_fetch_error', { provider: secondaryCreds.provider, ...sanitizeError(err) });
    return null;
  }
}

async function tryCodexJsonlFallback(creds, config, { generation } = {}) {
  try {
    const { parseCodexJsonlFallback } = await import('../lib/providers/codex.js');
    const fallback = await parseCodexJsonlFallback({ codexHome: process.env.CODEX_HOME });
    if (generation != null && generation !== fetchGeneration) return false;
    if (fallback) {
      cachedData = {
        ...fallback.rateLimits,
        balance: null,
        meta: buildMeta(config, { subscriptionType: creds.subscriptionType, provider: 'codex' }),
      };
      await writeUsageAtomic(cachedData);
      return true;
    }
  } catch (e) {
    logJson(console.error, 'codex_jsonl_fallback_failed', { error: String(e) });
  }
  return false;
}

function buildEmptyBroadcast(config, provider) {
  return {
    five_hour: null,
    seven_day: null,
    seven_day_sonnet: null,
    seven_day_opus: null,
    code_review: null,
    extra_usage: null,
    seven_day_oauth_apps: null,
    seven_day_cowork: null,
    seven_day_omelette: null,
    balance: null,
    copilot: null,
    secondary: null,
    meta: buildMeta(config, { provider: provider ?? 'unknown' }),
  };
}

async function fetchAndHandleBroadcast({ force = false } = {}) {
  if (fetchInFlight && !force) return fetchInFlight;
  if (force) {
    if (currentAbortController) currentAbortController.abort();
    fetchInFlight = null;
  }

  const generation = ++fetchGeneration;
  const abortController = new AbortController();
  currentAbortController = abortController;

  fetchInFlight = (async () => {
    const config = await readConfig();
    const creds = await readCredentials(config);
    const success = await fetchUsage(creds, config, { generation, signal: abortController.signal });

    if (generation !== fetchGeneration) return false;

    if (success) {
      currentInterval = POLL_INTERVAL;
      broadcast(cachedData);
      await thresholdNotifier.check(cachedData);
      await copilotThresholdNotifier.check(cachedData);
    } else {
      currentInterval = BACKOFF_INTERVAL;
      if (cachedData) {
        broadcast(cachedData);
      } else {
        broadcast(buildEmptyBroadcast(config, creds?.provider));
      }
    }
    return success;
  })();

  try {
    return await fetchInFlight;
  } finally {
    fetchInFlight = null;
  }
}

async function refreshNow() {
  const success = await fetchAndHandleBroadcast();
  if (!success && cachedData) {
    cachedData = {
      ...cachedData,
      meta: {
        ...cachedData.meta,
        fetchedAt: new Date().toISOString(),
      },
    };
    await writeUsageAtomic(cachedData);
    broadcast(cachedData);
    await thresholdNotifier.check(cachedData);
    await copilotThresholdNotifier.check(cachedData);
  }
}

async function pollLoop() {
  while (true) {
    await Bun.sleep(currentInterval);
    await fetchAndHandleBroadcast();
  }
}

function ensurePortAvailable() {
  try {
    const probe = Bun.listen({
      hostname: '127.0.0.1',
      port: WS_PORT,
      socket: { data() {}, open() {}, close() {}, error() {} },
    });
    probe.stop(true);
  } catch (err) {
    logError(`ai-gauge-server: port ${WS_PORT} already in use (${err?.code || err?.message || err})`);
    process.exit(1);
  }
}

async function handleSetConfig(cmd, ws) {
  const { key, value } = cmd;
  const validation = validateConfigChange(key, value);
  if (!validation.valid) {
    logError(`[setConfig] rejected: ${validation.reason}`);
    sendToClient(ws, { type: 'configError', key, value, reason: validation.reason });
    return;
  }

  let result;
  try {
    result = await applyConfigChange(key, value);
  } catch (err) {
    const reason = err instanceof Error ? err.message : String(err);
    logError(`[setConfig] write failed: ${reason}`);
    sendToClient(ws, { type: 'configError', key, value, reason: `write failed: ${reason}` });
    return;
  }

  if (!result.applied) {
    logError(`[setConfig] rejected: ${result.reason}`);
    sendToClient(ws, { type: 'configError', key, value, reason: result.reason });
    return;
  }

  logError(`[setConfig] applied: ${key}=${value}`);

  if (key === 'tokenSource') {
    cachedData = null;
    broadcast(buildEmptyBroadcast(result.config, 'unknown'));
    fetchAndHandleBroadcast({ force: true }).catch((err) => {
      const reason = err instanceof Error ? err.message : String(err);
      logError(`[setConfig] post-switch fetch failed: ${reason}`);
      // Re-broadcast an empty state so optimistic clients can recover instead of
      // staying stuck in "Switching…". The original empty broadcast above is
      // enough for clients that received it, but a second one is harmless and
      // covers the case where the client (re)connects mid-switch.
      try {
        broadcast(buildEmptyBroadcast(result.config, 'unknown'));
      } catch {}
      sendToClient(ws, { type: 'configError', key, value, reason: `fetch failed: ${reason}` });
    });
  } else if (cachedData) {
    cachedData = {
      ...cachedData,
      meta: {
        ...cachedData.meta,
        tokenSource: result.config.tokenSource,
        ...(key === 'plan' ? { plan: value } : {}),
        ...(key === 'autoCheckUpdates' ? { autoCheckUpdates: value } : {}),
        ...(key === 'displayMode' ? { displayMode: value } : {}),
      },
    };
    broadcast(cachedData);
  }

  if (key === 'autoCheckUpdates') {
    if (value === false) {
      updateLifecycle.cancel();
      logError('[update] auto-check disabled; scheduler cancelled');
    } else if (!updateLifecycle.isScheduled()) {
      logError('[update] auto-check enabled; scheduler restarted');
      updateLifecycle.schedule(UPDATE_CHECK_INITIAL_DELAY_MS);
    }
  }
}

function createServer() {
  try {
    return Bun.serve({
      port: WS_PORT,
      hostname: 'localhost',
      reusePort: false,
      fetch(req, serverInstance) {
        if (serverInstance.upgrade(req)) return;
        return new Response('WS only', { status: 426 });
      },
      websocket: {
        async open(ws) {
          addClient(ws);
          if (cachedData) {
            sendToClient(ws, cachedData);
          } else {
            // Even without fetched usage data, send a minimal payload so optimistic
            // clients (e.g. macOS menubar after applyOptimisticTokenSource) can
            // exit their "Switching…" state immediately on (re)connect rather
            // than waiting for the next poll.
            try {
              const config = await readConfig();
              sendToClient(ws, buildEmptyBroadcast(config, 'unknown'));
            } catch (err) {
              logError(`[ws.open] failed to send empty broadcast: ${err instanceof Error ? err.message : String(err)}`);
            }
          }
          const updatePayload = updateLifecycle.buildAvailablePayload();
          if (updatePayload) sendToClient(ws, updatePayload);
        },
        async message(ws, msg) {
          let cmd;
          try {
            cmd = JSON.parse(typeof msg === 'string' ? msg : Buffer.from(msg).toString('utf8'));
          } catch {
            return;
          }

          if (cmd?.type === 'refresh') {
            void refreshNow();
            return;
          }

          if (cmd?.type === 'listSettingsFiles') {
            const files = discoverSettingsFiles(CLAUDE_DIR).map((f) => ({
              name: f.name,
              provider: f.provider,
              baseUrl: f.baseUrl,
              hasToken: f.hasToken,
              supported: f.supported,
              ...(f.skipReason ? { skipReason: f.skipReason } : {}),
            }));
            sendToClient(ws, { type: 'settingsFiles', files });
            return;
          }

          if (cmd?.type === 'doUpdate') {
            void updateLifecycle.doInstall();
            return;
          }

          if (cmd?.type === 'checkUpdate') {
            void updateLifecycle.doCheck({ manual: true });
            return;
          }

          if (cmd?.type === 'dismissUpdate') {
            const version = typeof cmd.version === 'string' ? cmd.version : updateLifecycle.getState().latestVersion;
            void updateLifecycle.dismiss(version).then((result) => {
              if (result.dismissed) {
                logError(`[update] dismissed v${result.version}`);
              }
            });
            return;
          }

          if (cmd?.type === 'undismissUpdate') {
            void updateLifecycle.undismiss().then((result) => {
              if (result.undismissed) {
                logError(`[update] undismissed v${result.previous}`);
                void updateLifecycle.doCheck({ manual: true });
              }
            });
            return;
          }

          if (cmd?.type === 'setConfig') {
            await handleSetConfig(cmd, ws);
          }
        },
        close(ws) {
          removeClient(ws);
        },
      },
    });
  } catch (err) {
    const text = String(err);
    if (err?.code === 'EADDRINUSE' || text.includes('already in use') || text.includes('EADDRINUSE')) {
      logError(`ai-gauge-server: port ${WS_PORT} already in use`);
      process.exit(1);
    }
    throw err;
  }
}

function setupShutdown() {
  const shutdown = () => {
    try {
      updateLifecycle.cancel();
      server?.stop();
    } finally {
      process.exit(0);
    }
  };

  process.on('SIGTERM', shutdown);
  process.on('SIGINT', shutdown);
}

async function main() {
  const { mkdir } = await import('node:fs/promises');
  await mkdir(STATE_DIR, { recursive: true });
  const config = await readConfig();
  console.error(`token source: ${config.tokenSource}`);
  await detectClaudeVersion();
  const startupCreds = await readCredentials(config);
  if (startupCreds) {
    cachedData = await loadCachedUsage(`${STATE_DIR}/usage.json`, {
      expectedTokenSource: config.tokenSource,
      expectedProvider: startupCreds.provider,
      config,
      fallbackPlan: startupCreds.subscriptionType,
    });
  }
  await fetchAndHandleBroadcast();
  ensurePortAvailable();
  server = createServer();
  setupShutdown();
  console.error(`ai-gauge-server listening on ws://localhost:${WS_PORT}`);

  if (process.env.AIGAUGE_UPDATING === '1') {
    logError('[update] daemon restarted with AIGAUGE_UPDATING flag — possible failed previous update; resetting state');
  }

  await updateLifecycle.start();

  await pollLoop();
}

if (import.meta.main) {
  await main();
}

export { fetchUsage, readCredentials };
