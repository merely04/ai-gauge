{
  "name": "ai-gauge",
  "version": "1.5.2",
  "description": "Real-time Claude Code & OpenCode usage monitor. Native menubar (macOS), Waybar module (Linux), StreamDock plugin. Rate limits, alerts, countdowns.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/merely04/ai-gauge.git"
  },
  "author": "merely04",
  "bin": {
    "ai-gauge": "bin/ai-gauge",
    "ai-gauge-server": "bin/ai-gauge-server",
    "ai-gauge-waybar": "bin/ai-gauge-waybar",
    "ai-gauge-menu": "bin/ai-gauge-menu",
    "ai-gauge-config": "bin/ai-gauge-config"
  },
  "files": [
    "bin/",
    "lib/",
    "bin/ai-gauge-menubar",
    "bin/AIGauge.app/**",
    "lib/ai-gauge-server.plist.template",
    "lib/ai-gauge-menubar.plist.template",
    "README.md",
    "CHANGELOG.md",
    "docs/",
    "!**/*.test.js",
    "!test/"
  ],
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepare": "git config core.hooksPath .githooks || true",
    "validate-release": "bash scripts/validate-release.sh"
  },
  "keywords": [
    "waybar",
    "waybar-module",
    "claude-code",
    "claude",
    "anthropic",
    "opencode",
    "linux",
    "hyprland",
    "sway",
    "wayland",
    "monitoring",
    "usage-tracking",
    "developer-tools",
    "stream-deck",
    "status-bar",
    "ai-gauge",
    "rate-limiting",
    "ai-monitoring"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "os": [
    "linux",
    "darwin"
  ]
}
